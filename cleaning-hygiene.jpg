/* ============================================================
   NKS GROUP (PTY) LTD — WEBSITE STYLESHEET
   Color Palette extracted from logo:
   - Dark Charcoal/Navy:  #1a1f2e
   - Forest Green:        #2d5a27
   - Cream/Off-White:     #f0ead6
   - Gold Accent:         #c9a84c
   ============================================================ */

:root {
  --dark:       #1a1f2e;
  --dark-2:     #141820;
  --green:      #2d5a27;
  --green-2:    #3a7232;
  --cream:      #f0ead6;
  --cream-2:    #e8dfc5;
  --gold:       #c9a84c;
  --gold-2:     #e0bf6a;
  --white:      #ffffff;
  --text:       #2a2a2a;
  --text-light: #555555;
  --border:     rgba(201, 168, 76, 0.25);

  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Barlow', sans-serif;
  --font-cond: 'Barlow Condensed', sans-serif;

  --max-w: 1200px;
  --nav-h: 90px;
  --radius: 4px;
  --shadow: 0 4px 30px rgba(0,0,0,0.12);
  --transition: all 0.3s ease;
}

/* ── RESET ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); color: var(--text); background: var(--white); line-height: 1.7; overflow-x: hidden; }
img { max-width: 100%; height: auto; display: block; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; }

/* ── TYPOGRAPHY ── */
h1,h2,h3 { font-family: var(--font-display); font-weight: 600; line-height: 1.2; }
h1 { font-size: clamp(2.4rem, 5vw, 4rem); }
h2 { font-size: clamp(1.8rem, 3vw, 2.8rem); }
h3 { font-size: clamp(1.2rem, 2vw, 1.6rem); }
p  { font-size: 1rem; color: var(--text-light); line-height: 1.8; }

/* ── UTILITIES ── */
.container  { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }
.section    { padding: 90px 0; }
.dark-section { background: var(--dark); }
.dark-section p { color: rgba(240,234,214,0.75); }
.section-tag { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
.section-tag.light { color: var(--gold); }
.section-title { color: var(--dark); margin-bottom: 20px; }
.section-title.light { color: var(--cream); }
.section-lead { font-size: 1.1rem; max-width: 720px; margin-bottom: 48px; }
.section-lead.light { color: rgba(240,234,214,0.8); }
.section-lead.center { margin: 0 auto 48px; text-align: center; }
.center { text-align: center; }
.center-content { text-align: center; display: flex; flex-direction: column; align-items: center; }
.mt { margin-top: 32px; display: inline-block; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
.two-col.reverse .col-img { order: 2; }
.two-col.reverse .col-text { order: 1; }

/* ── BUTTONS ── */
.btn { display: inline-block; font-family: var(--font-cond); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 14px 32px; border-radius: var(--radius); transition: var(--transition); cursor: pointer; border: 2px solid transparent; }
.btn-primary { background: var(--gold); color: var(--dark); border-color: var(--gold); }
.btn-primary:hover { background: var(--gold-2); border-color: var(--gold-2); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,168,76,0.35); }
.btn-outline { background: transparent; color: var(--cream); border-color: rgba(240,234,214,0.5); }
.btn-outline:hover { background: rgba(240,234,214,0.1); border-color: var(--cream); }
.btn.full-width { width: 100%; text-align: center; }

/* ══════════════════════════════════════
   NAVIGATION
══════════════════════════════════════ */
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; height: var(--nav-h); background: rgba(26,31,46,0.97); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); transition: var(--transition); }
.navbar.scrolled { background: rgba(20,24,32,0.99); }
.nav-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; height: 100%; display: flex; align-items: center; justify-content: space-between; }
.nav-logo img { height: 72px; width: auto; }
.nav-links { display: flex; align-items: center; gap: 8px; }
.nav-links a { font-family: var(--font-cond); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(240,234,214,0.75); padding: 8px 12px; border-radius: var(--radius); transition: var(--transition); }
.nav-links a:hover, .nav-links a.active { color: var(--cream); }
.nav-links a.active { color: var(--gold); }
.nav-cta { background: var(--gold) !important; color: var(--dark) !important; padding: 8px 20px !important; margin-left: 8px; }
.nav-cta:hover { background: var(--gold-2) !important; }
.nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; }
.nav-toggle span { display: block; width: 24px; height: 2px; background: var(--cream); transition: var(--transition); }

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.hero { min-height: 100vh; background: var(--dark); display: grid; grid-template-columns: 1fr 1fr; align-items: center; padding: calc(var(--nav-h) + 60px) 80px 80px; gap: 60px; position: relative; overflow: hidden; }
.hero-bg-pattern { position: absolute; inset: 0; opacity: 0.04; background-image: repeating-linear-gradient(45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%); background-size: 30px 30px; pointer-events: none; }
.hero-badge { display: inline-block; font-family: var(--font-cond); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); border: 1px solid var(--border); padding: 6px 16px; border-radius: 2px; margin-bottom: 24px; }
.hero-title { color: var(--cream); margin-bottom: 24px; line-height: 1.1; }
.hero-title .accent { color: var(--gold); font-style: italic; }
.hero-sub { color: rgba(240,234,214,0.7); font-size: 1.05rem; max-width: 480px; margin-bottom: 40px; }
.hero-actions { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 56px; }
.hero-stats { display: flex; align-items: center; gap: 32px; }
.stat { display: flex; flex-direction: column; }
.stat-num { font-family: var(--font-display); font-size: 2.4rem; font-weight: 700; color: var(--gold); line-height: 1; }
.stat-label { font-family: var(--font-cond); font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(240,234,214,0.5); margin-top: 4px; }
.stat-divider { width: 1px; height: 48px; background: var(--border); }
.hero-visual { position: relative; }
.hero-img-frame { position: relative; border-radius: 6px; overflow: hidden; }
.hero-img-frame img { width: 100%; height: 520px; object-fit: cover; }
.hero-img-frame::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(201,168,76,0.2), transparent 60%); z-index: 1; }
.hero-img-tag { position: absolute; bottom: 24px; left: 24px; z-index: 2; background: rgba(26,31,46,0.9); color: var(--gold); font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; padding: 8px 16px; border-left: 3px solid var(--gold); }

/* ══════════════════════════════════════
   TRUST BAR
══════════════════════════════════════ */
.trust-bar { background: var(--green); padding: 16px 0; overflow: hidden; }
.trust-inner { display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; padding: 0 24px; }
.trust-inner span { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(240,234,214,0.9); }
.dot { color: var(--gold); font-size: 0.5rem; }

/* ══════════════════════════════════════
   EXEC SUMMARY
══════════════════════════════════════ */
.exec-summary { background: var(--cream); }
.exec-summary .section-title { color: var(--dark); }
.exec-summary p { margin-bottom: 16px; }
.value-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.value-card { background: var(--white); border: 1px solid rgba(26,31,46,0.1); border-radius: var(--radius); padding: 24px; border-top: 3px solid var(--gold); transition: var(--transition); }
.value-card:hover { box-shadow: var(--shadow); transform: translateY(-4px); }
.val-icon { font-size: 1.5rem; margin-bottom: 10px; }
.value-card strong { display: block; font-family: var(--font-display); font-size: 1.1rem; color: var(--dark); margin-bottom: 6px; }
.value-card p { font-size: 0.88rem; margin: 0; }

/* ══════════════════════════════════════
   SERVICES OVERVIEW (dark)
══════════════════════════════════════ */
.services-overview .section-title { color: var(--cream); }
.services-overview .section-tag { color: var(--gold); }
.services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 48px; }
.service-card { display: block; background: rgba(255,255,255,0.04); border: 1px solid var(--border); padding: 36px 28px; transition: var(--transition); position: relative; overflow: hidden; }
.service-card::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: var(--transition); }
.service-card:hover { background: rgba(201,168,76,0.08); transform: translateY(-4px); }
.service-card:hover::before { transform: scaleX(1); }
.svc-num { font-family: var(--font-display); font-size: 3rem; font-weight: 700; color: rgba(201,168,76,0.2); line-height: 1; margin-bottom: 12px; }
.service-card h3 { font-size: 1.15rem; color: var(--cream); margin-bottom: 12px; }
.service-card p { font-size: 0.9rem; color: rgba(240,234,214,0.6); margin: 0; }

/* ══════════════════════════════════════
   WHY CHOOSE US
══════════════════════════════════════ */
.why-us { background: var(--white); }
.why-us .section-title { text-align: center; }
.why-us .section-tag { text-align: center; }
.why-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 24px; margin-top: 48px; }
.why-card { background: var(--cream); border-radius: var(--radius); padding: 36px 24px; text-align: center; border-bottom: 3px solid transparent; transition: var(--transition); }
.why-card:hover { border-bottom-color: var(--gold); transform: translateY(-4px); box-shadow: var(--shadow); }
.why-icon { font-size: 2rem; margin-bottom: 16px; }
.why-card h3 { font-size: 1.1rem; color: var(--dark); margin-bottom: 10px; }
.why-card p { font-size: 0.88rem; }

/* ══════════════════════════════════════
   CTA BAND
══════════════════════════════════════ */
.cta-band { background: var(--green); padding: 80px 24px; text-align: center; }
.cta-band h2 { font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.4rem); color: var(--cream); margin-bottom: 16px; }
.cta-band p { color: rgba(240,234,214,0.8); margin-bottom: 32px; font-size: 1.05rem; }

/* ══════════════════════════════════════
   PAGE HERO (inner pages)
══════════════════════════════════════ */
.page-hero { background: var(--dark); padding: calc(var(--nav-h) + 80px) 24px 80px; text-align: center; position: relative; overflow: hidden; }
.page-hero::before { content: ''; position: absolute; inset: 0; opacity: 0.04; background-image: repeating-linear-gradient(45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%); background-size: 30px 30px; }
.page-hero-content { position: relative; z-index: 1; }
.page-hero h1 { color: var(--cream); margin-bottom: 16px; }
.page-hero p { color: rgba(240,234,214,0.75); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

/* ══════════════════════════════════════
   ABOUT — MVV
══════════════════════════════════════ */
.mvv-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
.mvv-card { border-radius: var(--radius); padding: 40px 32px; }
.mvv-card.mission { background: var(--dark); color: var(--cream); }
.mvv-card.vision  { background: var(--green); color: var(--cream); }
.mvv-card.values  { background: var(--cream); }
.mvv-icon { font-size: 2rem; margin-bottom: 16px; }
.mvv-card h3 { font-family: var(--font-display); font-size: 1.4rem; margin-bottom: 16px; color: var(--gold); }
.mvv-card p { font-size: 0.95rem; color: rgba(240,234,214,0.85); }
.mvv-card.values p { color: var(--text-light); }
.values-list { list-style: none; }
.values-list li { padding: 8px 0; border-bottom: 1px solid rgba(0,0,0,0.08); font-size: 0.9rem; color: var(--text-light); }
.values-list li:last-child { border-bottom: none; }

/* ══════════════════════════════════════
   ABOUT — TIMELINE
══════════════════════════════════════ */
.timeline-col { padding: 20px 0; }
.timeline { position: relative; }
.timeline::before { content:''; position: absolute; left: 60px; top: 0; bottom: 0; width: 2px; background: var(--border); }
.tl-item { display: flex; gap: 24px; margin-bottom: 40px; position: relative; }
.tl-year { font-family: var(--font-cond); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.1em; color: var(--gold); min-width: 60px; text-align: right; padding-top: 4px; }
.tl-body { background: rgba(255,255,255,0.06); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 20px; flex: 1; }
.tl-body strong { display: block; color: var(--cream); font-family: var(--font-display); font-size: 1.1rem; margin-bottom: 6px; }
.tl-body p { font-size: 0.88rem; color: rgba(240,234,214,0.65); margin: 0; }

/* ══════════════════════════════════════
   TEAM
══════════════════════════════════════ */
.team-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 32px; margin-bottom: 24px; }
.team-card { background: var(--white); border-radius: var(--radius); overflow: hidden; border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 2px 16px rgba(0,0,0,0.06); transition: var(--transition); }
.team-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(0,0,0,0.14); border-color: rgba(201,168,76,0.35); }
.team-photo-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; color: rgba(240,234,214,0.4); text-align: center; gap: 8px; width: 100%; height: 100%; background: var(--dark); }
.team-photo-placeholder span { font-size: 2.5rem; }
.team-photo-placeholder small { font-size: 0.78rem; font-family: var(--font-cond); letter-spacing: 0.1em; text-transform: uppercase; }
.team-info { padding: 28px 26px 24px; }
.team-info h3 { color: var(--dark); margin-bottom: 2px; font-size: 1.4rem; }
.team-title { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 14px; }
.team-info p { font-size: 0.88rem; color: var(--text-light); line-height: 1.75; }
.photo-note { text-align: center; font-size: 0.85rem; color: var(--text-light); background: #fffbf0; border: 1px dashed var(--gold); border-radius: var(--radius); padding: 12px 20px; margin-top: 24px; }
.photo-note code { background: rgba(201,168,76,0.15); padding: 1px 6px; border-radius: 3px; font-size: 0.8rem; }

/* Team photo overlay on hover */
.team-photo-wrap { position: relative; background: var(--dark); height: 300px; overflow: hidden; }
.team-photo-wrap img { width: 100%; height: 100%; object-fit: cover; object-position: top center; transition: transform 0.4s ease; filter: brightness(0.95); }
.team-photo-wrap:hover img { transform: scale(1.04); }
.team-photo-bw img { filter: grayscale(20%) brightness(1.05) contrast(1.05); }
.team-photo-bw:hover img { filter: grayscale(0%) brightness(1.05) contrast(1.05); }

.team-photo-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(26,31,46,0.92) 0%, rgba(26,31,46,0.4) 60%, transparent 100%); padding: 20px 20px 14px; opacity: 0; transition: opacity 0.3s ease; }
.team-photo-wrap:hover .team-photo-overlay { opacity: 1; }
.team-overlay-name { font-family: var(--font-display); font-size: 1.1rem; color: var(--cream); font-weight: 600; }

/* Role badge */
.team-role-badge { display: inline-block; font-family: var(--font-cond); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; background: var(--dark); color: var(--gold); padding: 4px 10px; border-radius: 2px; margin-bottom: 10px; }
.team-role-badge.management { background: var(--green); color: var(--cream); }

/* Contact links under bio */
.team-contact-row { display: flex; flex-direction: column; gap: 4px; margin-top: 14px; padding-top: 14px; border-top: 1px solid rgba(0,0,0,0.08); }
.team-contact-link { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; color: var(--green); letter-spacing: 0.05em; transition: var(--transition); }
.team-contact-link:hover { color: var(--gold); }

/* ══════════════════════════════════════
   IMPACT
══════════════════════════════════════ */
.impact-section { background: var(--dark); }
.impact-section .section-title { color: var(--cream); text-align: center; }
.impact-section .section-tag { text-align: center; }
.impact-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 24px; margin-top: 48px; }
.impact-card { text-align: center; border: 1px solid var(--border); border-radius: var(--radius); padding: 40px 20px; }
.impact-num { font-family: var(--font-display); font-size: 3.5rem; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 8px; }
.impact-label { font-family: var(--font-cond); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(240,234,214,0.6); }

/* ══════════════════════════════════════
   SERVICES DETAIL
══════════════════════════════════════ */
.service-detail { padding: 80px 24px; }
.service-detail .container { max-width: var(--max-w); margin: 0 auto; }
.alt-bg { background: var(--cream); }
.service-img { width: 100%; height: 420px; object-fit: cover; border-radius: var(--radius); box-shadow: var(--shadow); }

/* Dual image layout for services with 2 photos */
.service-img-duo { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.service-img-duo img { width: 100%; height: 280px; object-fit: cover; border-radius: var(--radius); box-shadow: var(--shadow); }
.service-img-duo img:first-child { grid-column: 1; }
.service-img-duo img:last-child { grid-column: 2; }

.svc-num-lg { font-family: var(--font-display); font-size: 5rem; font-weight: 700; color: rgba(26,31,46,0.08); line-height: 1; margin-bottom: -16px; }
.col-text h2 { color: var(--dark); margin-bottom: 16px; }
.col-text p { margin-bottom: 16px; }
.svc-features { list-style: none; margin: 20px 0 32px; }
.svc-features li { padding: 8px 0 8px 24px; position: relative; border-bottom: 1px solid rgba(0,0,0,0.06); font-size: 0.95rem; color: var(--text); }
.svc-features li::before { content: '◆'; position: absolute; left: 0; color: var(--gold); font-size: 0.5rem; top: 12px; }

/* ══════════════════════════════════════
   INDUSTRIES
══════════════════════════════════════ */
.industry-section { padding: 80px 24px; }
.industry-tag { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
.industry-services { margin: 24px 0 32px; }
.industry-services h4 { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-light); margin-bottom: 10px; }
.ind-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.ind-tags span { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; background: var(--dark); color: var(--gold); padding: 4px 12px; border-radius: 2px; letter-spacing: 0.08em; }
.target-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 48px; }
.target-card { border: 1px solid var(--border); border-radius: var(--radius); padding: 32px 24px; }
.target-card h3 { color: var(--gold); font-family: var(--font-display); font-size: 1.3rem; margin-bottom: 12px; }
.target-card p { font-size: 0.9rem; color: rgba(240,234,214,0.7); }

/* ══════════════════════════════════════
   COMMUNITY
══════════════════════════════════════ */
.csr-pillars { display: grid; grid-template-columns: repeat(4,1fr); gap: 24px; margin-top: 48px; }
.csr-pillar { text-align: center; padding: 32px 20px; border: 1px solid rgba(0,0,0,0.08); border-radius: var(--radius); border-top: 3px solid var(--gold); transition: var(--transition); }
.csr-pillar:hover { box-shadow: var(--shadow); transform: translateY(-4px); }
.csr-icon { font-size: 2rem; margin-bottom: 16px; }
.csr-pillar h3 { color: var(--dark); font-size: 1.05rem; margin-bottom: 10px; }
.csr-pillar p { font-size: 0.88rem; }
.csr-gallery { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 48px; }
.gallery-item { border-radius: var(--radius); overflow: hidden; background: rgba(255,255,255,0.04); border: 1px solid var(--border); }
.gallery-item img { width: 100%; height: 240px; object-fit: cover; }
.gallery-placeholder { height: 240px; display: flex; flex-direction: column; align-items: center; justify-content: center; color: rgba(240,234,214,0.3); text-align: center; gap: 8px; border-bottom: 1px solid var(--border); }
.gallery-placeholder span { font-size: 2rem; }
.gallery-placeholder p { font-size: 0.88rem; color: rgba(240,234,214,0.4); }
.gallery-placeholder small { font-size: 0.72rem; color: rgba(240,234,214,0.25); max-width: 200px; }
.gallery-caption { padding: 20px; }
.gallery-caption h4 { color: var(--cream); font-family: var(--font-display); font-size: 1.1rem; margin-bottom: 6px; }
.gallery-caption p { font-size: 0.85rem; color: rgba(240,234,214,0.6); margin: 0; }

/* ══════════════════════════════════════
   CAREERS
══════════════════════════════════════ */
.vacancies-list { margin-top: 48px; display: flex; flex-direction: column; gap: 24px; }
.vacancy-card { background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: var(--radius); padding: 36px; border-left: 4px solid var(--gold); transition: var(--transition); }
.vacancy-card:hover { background: rgba(255,255,255,0.08); }
.vacancy-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
.vacancy-title { color: var(--cream); font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 10px; }
.vacancy-meta { display: flex; gap: 12px; flex-wrap: wrap; }
.vacancy-tag { font-family: var(--font-cond); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; color: rgba(240,234,214,0.6); background: rgba(255,255,255,0.06); padding: 4px 10px; border-radius: 2px; }
.vacancy-date { font-family: var(--font-cond); font-size: 0.75rem; font-weight: 600; color: var(--gold); white-space: nowrap; }
.vacancy-body { border-top: 1px solid var(--border); padding-top: 20px; margin-bottom: 24px; }
.vacancy-body p { color: rgba(240,234,214,0.75); margin-bottom: 16px; }
.vacancy-body h4 { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
.vacancy-body ul { list-style: disc; padding-left: 20px; }
.vacancy-body ul li { color: rgba(240,234,214,0.7); font-size: 0.9rem; margin-bottom: 4px; }
.vacancy-footer { display: flex; align-items: center; gap: 24px; }
.vacancy-ref { font-family: var(--font-cond); font-size: 0.75rem; color: rgba(240,234,214,0.4); }
.no-vacancies { text-align: center; padding: 60px; border: 1px dashed var(--border); border-radius: var(--radius); margin-top: 48px; }
.nv-icon { font-size: 3rem; margin-bottom: 16px; }
.no-vacancies h3 { color: var(--cream); font-family: var(--font-display); font-size: 1.6rem; margin-bottom: 12px; }
.no-vacancies p { color: rgba(240,234,214,0.65); }
.no-vacancies a { color: var(--gold); text-decoration: underline; }

/* ══════════════════════════════════════
   CONTACT
══════════════════════════════════════ */
.contact-section { background: var(--cream); }
.contact-cols { gap: 80px; align-items: flex-start; }
.contact-info .section-title { color: var(--dark); }
.contact-info p { margin-bottom: 32px; }
.contact-cards { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
.contact-card { display: flex; align-items: center; gap: 16px; background: var(--white); border: 1px solid rgba(0,0,0,0.08); border-radius: var(--radius); padding: 16px 20px; transition: var(--transition); }
.contact-card:hover { box-shadow: var(--shadow); }
.contact-card-icon { font-size: 1.4rem; min-width: 40px; text-align: center; }
.contact-card h4 { font-family: var(--font-cond); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-light); margin-bottom: 4px; }
.contact-card p, .contact-card a { font-size: 0.95rem; color: var(--dark); font-weight: 500; }
.contact-card a:hover { color: var(--green); }
.contact-badge { display: flex; flex-wrap: wrap; gap: 8px; }
.contact-badge span { font-family: var(--font-cond); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; background: var(--dark); color: var(--gold); padding: 5px 12px; border-radius: 2px; }
.contact-form-wrap { background: var(--white); border-radius: var(--radius); padding: 40px; box-shadow: var(--shadow); }
.contact-form-wrap h3 { font-family: var(--font-display); font-size: 1.6rem; color: var(--dark); margin-bottom: 8px; }
.form-note { font-size: 0.88rem; color: var(--text-light); margin-bottom: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { margin-bottom: 20px; }
.form-group label { display: block; font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); margin-bottom: 6px; }
.form-group input, .form-group select, .form-group textarea { width: 100%; font-family: var(--font-body); font-size: 0.95rem; border: 1.5px solid #ddd; border-radius: var(--radius); padding: 12px 14px; background: var(--white); color: var(--text); transition: var(--transition); outline: none; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(201,168,76,0.15); }
.form-group textarea { resize: vertical; min-height: 120px; }

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
.footer { background: var(--dark-2); padding: 64px 24px 0; }
.footer-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid var(--border); }
.footer-logo { height: 90px; width: auto; margin-bottom: 16px; }
.footer-brand p { color: rgba(240,234,214,0.65); font-size: 0.9rem; line-height: 1.8; }
.footer-tag { color: var(--gold) !important; font-family: var(--font-cond); font-size: 0.78rem !important; letter-spacing: 0.15em; text-transform: uppercase; margin-top: 8px; }
.footer-links h4, .footer-contact h4 { font-family: var(--font-cond); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
.footer-links ul li { margin-bottom: 10px; }
.footer-links a { color: rgba(240,234,214,0.6); font-size: 0.9rem; transition: var(--transition); }
.footer-links a:hover { color: var(--gold); }
.footer-contact p { color: rgba(240,234,214,0.65); font-size: 0.9rem; margin-bottom: 6px; }
.footer-contact a { color: rgba(240,234,214,0.65); font-size: 0.9rem; transition: var(--transition); }
.footer-contact a:hover { color: var(--gold); }
.footer-bottom { max-width: var(--max-w); margin: 0 auto; padding: 20px 0; text-align: center; }
.footer-bottom p { font-size: 0.78rem; color: rgba(240,234,214,0.35); }

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@media (max-width: 1024px) {
  .hero { grid-template-columns: 1fr; padding: calc(var(--nav-h) + 40px) 40px 60px; }
  .hero-visual { display: none; }
  .why-grid { grid-template-columns: repeat(2,1fr); }
  .services-grid { grid-template-columns: repeat(2,1fr); }
  .team-grid { grid-template-columns: 1fr 1fr; }
  .team-grid .team-card:last-child { grid-column: 1 / -1; max-width: 380px; margin: 0 auto; }
  .csr-pillars { grid-template-columns: repeat(2,1fr); }
  .footer-inner { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}

@media (max-width: 768px) {
  .nav-links { display: none; flex-direction: column; position: absolute; top: var(--nav-h); left: 0; right: 0; background: var(--dark-2); padding: 20px 24px; gap: 4px; border-bottom: 1px solid var(--border); }
  .nav-links.open { display: flex; }
  .nav-links a { padding: 12px 16px; display: block; border-radius: var(--radius); }
  .nav-toggle { display: flex; }
  .two-col { grid-template-columns: 1fr; }
  .two-col.reverse .col-img { order: 0; }
  .two-col.reverse .col-text { order: 0; }
  .mvv-grid { grid-template-columns: 1fr; }
  .impact-grid { grid-template-columns: repeat(2,1fr); }
  .services-grid { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; }
  .csr-gallery { grid-template-columns: 1fr; }
  .target-grid { grid-template-columns: 1fr; }
  .hero-stats { flex-direction: column; align-items: flex-start; gap: 16px; }
  .stat-divider { display: none; }
  .hero-actions { flex-direction: column; }
  .form-row { grid-template-columns: 1fr; }
  .contact-cols { grid-template-columns: 1fr; }
  .team-grid { grid-template-columns: 1fr; }
  .team-grid .team-card:last-child { grid-column: auto; max-width: 100%; }
  .csr-pillars { grid-template-columns: 1fr; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  .vacancy-header { flex-direction: column; gap: 8px; }
  .trust-inner { gap: 10px; }
  .service-img-duo { grid-template-columns: 1fr; }
  .service-img-duo img { height: 220px; }
}
